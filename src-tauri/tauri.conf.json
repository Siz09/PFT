{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartSpend",
  "version": "1.0.0",
  "identifier": "com.smartspend.app",
  "build": {
    "devUrl": "http://localhost:8081",
    "beforeBuildCommand": "npm run web -- --platform web",
    "frontendDist": "../web-build"
  },
  "app": {
    "windows": [
      {
        "title": "SmartSpend",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.anthropic.com; img-src 'self' data: blob:; font-src 'self' data:; frame-src 'none';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
