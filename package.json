{
  "name": "smartspend",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@smartspend/web",
    "dev:web": "npm run dev --workspace=@smartspend/web",
    "dev:mobile": "npm run start --workspace=@smartspend/mobile",
    "dev:desktop": "npm run tauri:dev --workspace=@smartspend/web",
    "build": "npm run build --workspace=@smartspend/web",
    "build:web": "npm run build --workspace=@smartspend/web",
    "build:desktop": "npm run tauri:build --workspace=@smartspend/web",
    "preview": "npm run preview --workspace=@smartspend/web",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspace=@smartspend/web --if-present"
  }
}
